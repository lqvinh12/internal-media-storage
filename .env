APP_ENV=dev

# Domain (used by Nginx server_name and FastAPI response URL)
DOMAIN=media.local

# Server
PORT=8000

# Upload limits
MAX_FILE_SIZE=10485760
NGINX_MAX_BODY_SIZE=104857600
ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,ppt,pptx,txt

# Storage
MEDIA_ROOT=/app/data/media

# URL returned in upload response
BASE_URL=https://media.local/files
